                  {
                      "parameters":  {
                                         "jsCode":  "const q = (v) =\u003e `\"${String(v ?? \u0027\u0027).replace(/\"/g, \u0027\\\\\"\u0027)}\"`;\n\nconst fixedPromptFile = $json.fixed_prompt_file_path;\nconst imagePath = $json.product_image_path;\nconst keywords = $json.amazon_keywords;\n\nconst outputDir = $json.output_dir || \u0027E:\\\\codex\\\\output\\\\gemini_rpa\u0027;\nconst sessionDir = $json.session_dir || \u0027E:\\\\codex\\\\.gemini_profile\u0027;\n\nconst maxRetry = $json.max_retry || 5;\nconst retryWait = $json.retry_wait_sec || 15;\nconst taskGap = $json.task_gap_sec || 3;\nconst genTimeout = $json.gen_timeout_sec || 240;\nconst loginWait = $json.login_wait_sec || 600;\nconst headless = ($json.headless || \u0027false\u0027).toString();\nconst openNewChat = ($json.open_new_chat || \u0027true\u0027).toString();\n\nif (!fixedPromptFile || !imagePath || !keywords) {\n  throw new Error(\u0027fixed_prompt_file_path, product_image_path, amazon_keywords are required\u0027);\n}\n\nconst scriptPath = \u0027E:\\\\codex\\\\scripts\\\\gemini_web_rpa_worker.js\u0027;\n\nconst command = [\n  \u0027node\u0027, q(scriptPath),\n  \u0027--fixed-prompt-file\u0027, q(fixedPromptFile),\n  \u0027--image-path\u0027, q(imagePath),\n  \u0027--keywords\u0027, q(keywords),\n  \u0027--output-dir\u0027, q(outputDir),\n  \u0027--session-dir\u0027, q(sessionDir),\n  \u0027--max-retry\u0027, q(maxRetry),\n  \u0027--retry-wait-sec\u0027, q(retryWait),\n  \u0027--task-gap-sec\u0027, q(taskGap),\n  \u0027--gen-timeout-sec\u0027, q(genTimeout),\n  \u0027--login-wait-sec\u0027, q(loginWait),\n  \u0027--headless\u0027, q(headless),\n  \u0027--open-new-chat\u0027, q(openNewChat),\n  \u0027--attach-each-task\u0027, q(\u0027false\u0027)\n].join(\u0027 \u0027);\n\nreturn [{ json: { ...$json, command, script_path: scriptPath } }];"
                                     },
